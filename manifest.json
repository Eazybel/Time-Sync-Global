{
  "manifest_version": 3,
  "name": "Time-Sync Global",
  "description": "Global Time Zone Converter",
  "version": "1.0",
"host_permissions": [
    "https://api.opentimezone.com/*",
    "https://cdn.jsdelivr.net/tailwind"
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": "icon.png"
  }
}
